<!-- ══════════════════════════════════════════
     Main Content
══════════════════════════════════════════ -->
<main>

  <!-- ── Section: Home (Exercise 3) ── -->
  <section id="home">

    <!-- Exercise 3: Welcome Banner with blue background via internal CSS -->
    <div id="welcomeBanner">
      <p class="section-label">Welcome back, Resident</p>
      <h1>Your City.<br>Your Community.</h1>
      <p style="margin-top:0.75rem; color:#a8c8f0;">
        Discover local events, register in seconds, and stay connected.
        <span style="color: red; font-weight: bold;">🎉 Special Offer: Free entry this week!</span>
      </p>
      <p class="highlight" style="margin-top:1.2rem;">
         3 events near you this weekend
      </p>
    </div>

  </section>

  <hr class="divider">

  <!-- ── Section: Events & Gallery (Exercise 4) ── -->
  <section id="events">
    <div class="badge">Exercise 4</div>
    <p class="section-label">Community Highlights</p>
    <h2>Past Event Gallery</h2>

    <!-- Table with 2 rows × 3 columns of images -->
    <table class="gallery-table">
      <tr>
        <td>
          <figure ondblclick="enlargeImg(this)">
            <img class="event-img img-bordered"
                 src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=400&q=70"
                 alt="Community Meetup photo" title="Annual Community Meetup 2024">
            <figcaption>Annual Community Meetup – City Hall, Jan 2024</figcaption>
          </figure>
        </td>
        <td>
          <figure ondblclick="enlargeImg(this)">
            <img class="event-img img-bordered"
                 src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=400&q=70"
                 alt="Tech Fair photo" title="Tech & Innovation Fair 2024">
            <figcaption>Tech & Innovation Fair – Convention Centre, Mar 2024</figcaption>
          </figure>
        </td>
        <td>
          <figure ondblclick="enlargeImg(this)">
            <img class="event-img img-bordered"
                 src="https://images.unsplash.com/photo-1464047736614-af63643285bf?w=400&q=70"
                 alt="Green City Drive photo" title="Green City Drive 2024">
            <figcaption>Green City Drive – Riverside Park, Apr 2024</figcaption>
          </figure>
        </td>
      </tr>
      <tr>
        <td>
          <figure ondblclick="enlargeImg(this)">
            <img class="event-img img-bordered"
                 src="https://images.unsplash.com/photo-1511795409834-ef04bbd61622?w=400&q=70"
                 alt="Food Festival photo" title="Street Food Festival 2024">
            <figcaption>Street Food Festival – Main Square, May 2024</figcaption>
          </figure>
        </td>
        <td>
          <figure ondblclick="enlargeImg(this)">
            <img class="event-img img-bordered"
                 src="https://images.unsplash.com/photo-1543269865-cbf427effbad?w=400&q=70"
                 alt="Youth Sports Day photo" title="Youth Sports Day 2024">
            <figcaption>Youth Sports Day – Central Stadium, Jun 2024</figcaption>
          </figure>
        </td>
        <td>
          <figure ondblclick="enlargeImg(this)">
            <img class="event-img img-bordered"
                 src="https://images.unsplash.com/photo-1501281668745-f7f57925c3b4?w=400&q=70"
                 alt="Music Night photo" title="Summer Music Night 2024">
            <figcaption>Summer Music Night – Amphitheatre, Jul 2024</figcaption>
          </figure>
        </td>
      </tr>
    </table>
    <p style="font-size:0.8rem;color:var(--muted);margin-top:0.75rem;">
       <em>Double-click any image to enlarge it.</em>
    </p>
  </section>

  <hr class="divider">

  <!-- ── Section: Registration Form (Exercise 5) ── -->
  <section id="register">
    <div class="badge">Exercise 5</div>
    <p class="section-label">Sign Up</p>
    <h2>Event Registration</h2>

    <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:2rem;">
      <div class="form-grid">

        <!-- Name -->
        <div class="form-group">
          <label for="regName">Full Name *</label>
          <input type="text" id="regName" name="name"
                 placeholder="Jane Doe"
                 required autofocus>
        </div>

        <!-- Email -->
        <div class="form-group">
          <label for="regEmail">Email Address *</label>
          <input type="email" id="regEmail" name="email"
                 placeholder="jane@example.com" required>
        </div>

        <!-- Date -->
        <div class="form-group">
          <label for="regDate">Event Date *</label>
          <input type="date" id="regDate" name="date" required>
        </div>

        <!-- Event Type -->
        <div class="form-group">
          <label for="regEvent">Event Type *</label>
          <select id="regEvent" name="event" required
                  onchange="showFee(this); savePreference(this);">
            <option value="">— Select an event —</option>
            <option value="meetup">Community Meetup – Free</option>
            <option value="tech">Tech Fair – ₹199</option>
            <option value="green">Green Drive – Free</option>
            <option value="food">Food Festival – ₹149</option>
            <option value="sports">Sports Day – ₹99</option>
            <option value="music">Music Night – ₹249</option>
          </select>
          <div id="feeDisplay"></div>
        </div>

        <!-- Phone (Exercise 6 – blur validation) -->
        <div class="form-group">
          <label for="regPhone">Phone Number</label>
          <input type="tel" id="regPhone" name="phone"
                 placeholder="+91 98765 43210"
                 onblur="validatePhone(this)">
          <span id="phoneError">⚠ Please enter a valid 10-digit phone number.</span>
        </div>

        <!-- Message -->
        <div class="form-group form-full">
          <label for="regMessage">Message / Special Requests</label>
          <textarea id="regMessage" name="message"
                    placeholder="Any dietary needs, accessibility requirements…"
                    onkeyup="countChars(this)"></textarea>
          <div class="char-count"><span id="charNum">0</span> / 300 characters</div>
        </div>

      </div><!-- /form-grid -->

      <div style="display:flex;gap:1rem;align-items:center;margin-top:1.5rem;flex-wrap:wrap;">
        <button class="btn-primary"
                onclick="submitRegistration()">Register Now</button>
        <button class="btn-secondary"
                onclick="clearForm()">Clear</button>
      </div>

      <!-- Output element for confirmation (Exercise 5) -->
      <output id="confirmOutput"></output>
    </div>
  </section>

  <hr class="divider">

  <!-- ── Section: Feedback / Event Handling (Exercise 6) ── -->
  <section id="feedback">
    <div class="badge">Exercise 6</div>
    <p class="section-label">Share Your Experience</p>
    <h2>Event Feedback</h2>

    <div class="feedback-grid">

      <!-- Feedback form card -->
      <div class="feedback-card">
        <h3>Leave Feedback</h3>

        <div class="form-group" style="margin-bottom:1rem;">
          <label>Select Event</label>
          <select onchange="showFee(this)">
            <option value="">— Pick event to see fee paid —</option>
            <option value="meetup">Community Meetup – Free</option>
            <option value="tech">Tech Fair – ₹199</option>
            <option value="food">Food Festival – ₹149</option>
            <option value="sports">Sports Day – ₹99</option>
            <option value="music">Music Night – ₹249</option>
          </select>
          <div id="feedbackFeeDisplay" style="margin-top:0.4rem;color:var(--green);font-size:0.9rem;min-height:1.4em;"></div>
        </div>

        <div class="form-group" style="margin-bottom:1rem;">
          <label for="fbPhone">Phone (blur to validate)</label>
          <input type="tel" id="fbPhone" placeholder="10-digit number"
                 onblur="validatePhone(this)">
        </div>

        <div class="form-group" style="margin-bottom:1rem;">
          <label for="fbText">Your Feedback</label>
          <textarea id="fbText" rows="4"
                    placeholder="Write your thoughts…"
                    onkeyup="countChars(this, 'fbCharNum')"></textarea>
          <div class="char-count"><span id="fbCharNum">0</span> / 300 characters</div>
        </div>

        <button class="btn-primary"
                onclick="submitFeedback()">Submit Feedback</button>
        <div id="feedbackResult" style="margin-top:0.75rem;font-size:0.9rem;color:var(--green);min-height:1.2em;"></div>
      </div>

      <!-- Image enlarge card -->
      <div class="feedback-card">
        <h3>Event Snapshot</h3>
        <p style="font-size:0.82rem;color:var(--muted);margin-bottom:0.75rem;">
          Double-click the image to enlarge / restore.
        </p>
        <img id="eventThumb"
             src="https://images.unsplash.com/photo-1501281668745-f7f57925c3b4?w=600&q=70"
             alt="Event snapshot"
             ondblclick="toggleEnlarge(this)">
        <p style="font-size:0.78rem;color:var(--muted);margin-top:0.5rem;">
          Summer Music Night 2024
        </p>
      </div>

    </div><!-- /feedback-grid -->
  </section>

  <hr class="divider">

  <!-- ── Section: Video Invite (Exercise 7) ── -->
  <section id="video">
    <div class="badge">Exercise 7</div>
    <p class="section-label">Event Promo</p>
    <h2>Watch the Invite</h2>

    <video controls
           oncanplay="videoReady()"
           onended="videoEnded()">
      <!--
        Replace the src below with your own .mp4 file.
        Using a royalty-free sample from the web for demo:
      -->
      <source src="https://www.w3schools.com/html/mov_bbb.mp4" type="video/mp4">
      Your browser does not support the HTML5 video element.
    </video>
    <div id="videoStatus">Loading video…</div>
  </section>

  <hr class="divider">

  <!-- ── Section: Preferences (Exercise 8) ── -->
  <section id="preferences">
    <div class="badge">Exercise 8</div>
    <p class="section-label">Personalise</p>
    <h2>Your Preferences</h2>

    <p style="color:var(--muted);font-size:0.9rem;">
      Your last selected event type is saved automatically in
      <code style="color:var(--blue);background:rgba(74,144,217,0.1);padding:2px 6px;border-radius:4px;">localStorage</code>.
      It will be pre-selected on your next visit.
    </p>

    <div class="pref-row">
      <div id="storedPref">No saved preference yet.</div>
      <button class="btn-secondary" onclick="clearPreferences()">🗑 Clear Preferences</button>
    </div>
  </section>

  <hr class="divider">

  <!-- ── Section: Geolocation (Exercise 9) ── -->
  <section id="contact">
    <div class="badge">Exercise 9</div>
    <p class="section-label">Find Events Near You</p>
    <h2>Event Locator</h2>

    <p style="color:var(--muted);font-size:0.9rem;margin-bottom:1.2rem;">
      Allow location access to discover events closest to you.
    </p>
    <button class="btn-primary" onclick="findNearbyEvents()">
      Find Nearby Events
    </button>
    <div id="geoResult">Click the button above to detect your location.</div>
  </section>

  <hr class="divider">

  <!-- ── Section: DevTools Tips (Exercise 10) ── -->
  <section id="devtools">
    <div class="badge">Exercise 10</div>
    <p class="section-label">Developer Notes</p>
    <h2>Debugging with Chrome DevTools</h2>

    <div class="devtools-card">
      <p style="color:var(--muted);font-size:0.9rem;">
        This portal demonstrates several debugging hooks. Open
        <strong>Chrome DevTools</strong> (<kbd>F12</kbd>) to explore:
      </p>
      <ul>
        <li><strong>Elements tab</strong> – Inspect &amp; live-edit any CSS property.</li>
        <li><strong>Console tab</strong> – All events log with <code>console.log()</code> — try clicking buttons.</li>
        <li><strong>Sources tab</strong> – Add breakpoints inside any JS function (e.g. <code>submitRegistration</code>).</li>
