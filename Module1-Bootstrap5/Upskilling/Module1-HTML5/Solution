<script>

/* ─────────────────────────────────────────
   Exercise 5 – Form Submission & Output
───────────────────────────────────────── */
function submitRegistration() {
  const name    = document.getElementById('regName').value.trim();
  const email   = document.getElementById('regEmail').value.trim();
  const date    = document.getElementById('regDate').value;
  const event   = document.getElementById('regEvent').value;
  const output  = document.getElementById('confirmOutput');

  console.log('[Registration] Submit clicked', { name, email, date, event });

  if (!name || !email || !date || !event) {
    output.textContent = '⚠ Please fill in all required fields.';
    output.style.color = 'var(--red)';
    output.style.borderColor = 'var(--red)';
    output.style.background  = 'rgba(224,85,85,0.08)';
    return;
  }

  output.textContent =
    `Thank you, ${name}! You're registered for "${event}" on ${date}. Confirmation sent to ${email}.`;
  output.style.color       = 'var(--green)';
  output.style.borderColor = 'var(--green)';
  output.style.background  = 'rgba(78,203,132,0.08)';
}

function clearForm() {
  ['regName','regEmail','regDate','regPhone','regMessage'].forEach(id => {
    document.getElementById(id).value = '';
  });
  document.getElementById('regEvent').selectedIndex = 0;
  document.getElementById('confirmOutput').textContent = '';
  document.getElementById('feeDisplay').textContent = '';
  document.getElementById('charNum').textContent = '0';
  console.log('[Form] Cleared');
}


/* ─────────────────────────────────────────
   Exercise 6 – Event Handlers

   onblur  → phone validation
   onchange→ fee display  (also called from Exercise 5 dropdown)
   onclick → submit confirm (handled in submitRegistration/submitFeedback)
   ondblclick → image enlarge (toggleEnlarge)
   onkeyup → char counter
───────────────────────────────────────── */

/* onblur – phone validation */
function validatePhone(input) {
  const digits = input.value.replace(/\D/g,'');
  const errEl  = document.getElementById('phoneError');

  if (input.value === '') {
    input.classList.remove('invalid');
    if (errEl) errEl.style.display = 'none';
    return;
  }

  if (digits.length < 10) {
    input.classList.add('invalid');
    if (errEl) errEl.style.display = 'block';
    console.warn('[Phone] Invalid number:', input.value);
  } else {
    input.classList.remove('invalid');
    if (errEl) errEl.style.display = 'none';
    console.log('[Phone] Valid:', digits);
  }
}

/* onchange – show event fee */
const fees = {
  meetup: 'Free entry ',
  tech:   '₹199 per person',
  green:  'Free entry',
  food:   '₹149 per person',
  sports: '₹99 per person',
  music:  '₹249 per person',
};

function showFee(selectEl) {
  const val = selectEl.value;
  const fee = fees[val] || '';

  /* Determine which display element to update */
  const displayEl = selectEl.closest('#register')
    ? document.getElementById('feeDisplay')
    : document.getElementById('feedbackFeeDisplay');

  if (displayEl) {
    displayEl.textContent = val ? `Entry fee: ${fee}` : '';
    console.log('[Fee]', val, fee);
  }
}

/* onclick – feedback submit */
function submitFeedback() {
  const text = document.getElementById('fbText').value.trim();
  const result = document.getElementById('feedbackResult');
  console.log('[Feedback] Submitted:', text.slice(0,50));
  result.textContent = text
    ? 'Thank you for your feedback!'
    : 'Please write some feedback before submitting.';
}

/* ondblclick – image enlarge / restore */
function toggleEnlarge(img) {
  img.classList.toggle('enlarged');
  console.log('[Image] Enlarged:', img.classList.contains('enlarged'));
}

/* Gallery figure enlarge (Exercise 4 double-click) */
function enlargeImg(figure) {
  const img = figure.querySelector('img');
  if (img) toggleEnlarge(img);
}

/* onkeyup – character counter */
function countChars(textarea, spanId) {
  const id  = spanId || 'charNum';
  const len = textarea.value.length;
  document.getElementById(id).textContent = len;
  if (len > 300) textarea.value = textarea.value.slice(0, 300);
  console.log('[Chars]', len);
}


/* ─────────────────────────────────────────
   Exercise 7 – Media Events
───────────────────────────────────────── */
function videoReady() {
  const status = document.getElementById('videoStatus');
  status.textContent = 'Video ready to play!';
  console.log('[Video] oncanplay fired');
}

function videoEnded() {
  document.getElementById('videoStatus').textContent = 'Video finished. Thanks for watching!';
  console.log('[Video] ended');
}

/* onbeforeunload – warn if form is partially filled */
window.addEventListener('beforeunload', function(e) {
  const name = document.getElementById('regName').value.trim();
  if (name) {
    const msg = 'You have an unfinished registration. Are you sure you want to leave?';
    e.preventDefault();
    e.returnValue = msg;
    return msg;
  }
});


/* ─────────────────────────────────────────
   Exercise 8 – localStorage & sessionStorage
───────────────────────────────────────── */
function savePreference(selectEl) {
  const val = selectEl.value;
  if (!val) return;

  localStorage.setItem('preferredEvent', val);
  sessionStorage.setItem('sessionEvent', val);
  console.log('[Storage] Saved preferredEvent:', val);
  showStoredPreference();
}

function showStoredPreference() {
  const stored = localStorage.getItem('preferredEvent');
  const el     = document.getElementById('storedPref');
  if (stored) {
    el.textContent = `Saved preference: ${stored}`;

    /* Pre-select the dropdown */
    const regSelect = document.getElementById('regEvent');
    if (regSelect) {
      regSelect.value = stored;
      const fakeEl = { value: stored, closest: () => document.getElementById('register') };
      showFee({ value: stored, closest: () => document.getElementById('register') });
    }
  } else {
    el.textContent = 'No saved preference yet.';
  }
}

function clearPreferences() {
  localStorage.clear();
  sessionStorage.clear();
  document.getElementById('storedPref').textContent = 'Preferences cleared.';
  console.log('[Storage] Cleared localStorage & sessionStorage');
}

/* On page load: restore saved preference */
window.addEventListener('DOMContentLoaded', () => {
  showStoredPreference();
  console.log('[Portal] CityConnect loaded ');
});


/* ─────────────────────────────────────────
   Exercise 9 – Geolocation
───────────────────────────────────────── */
function findNearbyEvents() {
  const resultEl = document.getElementById('geoResult');
  resultEl.textContent = 'Detecting your location…';
  console.log('[Geo] Requesting position…');

  if (!navigator.geolocation) {
    resultEl.textContent = 'Geolocation is not supported by your browser.';
    return;
  }

  const options = {
    enableHighAccuracy: true,   /* high accuracy */
    timeout: 8000,              /* 8 s timeout   */
    maximumAge: 0               /* no cached pos */
  };

  navigator.geolocation.getCurrentPosition(
    /* success */
    function(pos) {
      const lat = pos.coords.latitude.toFixed(5);
      const lon = pos.coords.longitude.toFixed(5);
      const acc = pos.coords.accuracy.toFixed(1);
      resultEl.innerHTML =
        `Location found!<br>
         Latitude: <span class="coord-item">${lat}</span> &nbsp;
         Longitude: <span class="coord-item">${lon}</span><br>
         Accuracy: ±${acc} m<br><br>
         <strong>2 events found within 5 km</strong> – Community Meetup &amp; Tech Fair.`;
      console.log('[Geo] Position:', lat, lon, 'accuracy:', acc, 'm');
    },
    /* error */
    function(err) {
      let msg = '';
      switch(err.code) {
        case err.PERMISSION_DENIED:
          msg = 'Location access denied. Please allow location in browser settings.';
          break;
        case err.POSITION_UNAVAILABLE:
          msg = '⚠ Location information unavailable.';
          break;
        case err.TIMEOUT:
          msg = '⏱ Request timed out. Try again.';
          break;
        default:
          msg = '❌ An unknown error occurred.';
      }
      resultEl.textContent = msg;
      console.error('[Geo] Error:', err.message);
    },
    options
  );
}


